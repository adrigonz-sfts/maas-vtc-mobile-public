VITE_ENV=development
VITE_APP_BASE_URL=http://localhost:5173

# Deployed dev/stg/prod values come from Vault and are rendered into /runtime-config.js.
VITE_AUTH_API_BASE_URL=https://gw-dev.softoursistemas.com/auth
VITE_API_BASE_URL=https://gw-dev.softoursistemas.com
# Native OAuth redirect (custom URL scheme). Must match Android intent-filter / iOS URL types.
VITE_FRONTEND_REDIRECT_ORIGIN=com.softour.maasfrontend://login

# Android emulator dev server: use http://10.0.2.2:<PORT> instead of localhost (e.g. http://10.0.2.2:5173).
