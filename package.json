{
    "name": "maas-fe-mobile-template-public",
    "version": "1.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:app": "vite build --config vite.app.config.ts",
        "cap:sync": "npm run build:app && npx cap sync",
        "build:android": "npm run build:app && npx cap sync android",
        "build:ios": "npm run build:app && npx cap sync ios && npx cap open ios",
        "type-check": "vue-tsc --noEmit",
        "test": "vitest",
        "test:ci": "vitest --run --passWithNoTests",
        "test:e2e": "bddgen && playwright test",
        "test:e2e:gen": "bddgen",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:e2e:report": "playwright show-report",
        "coverage": "vitest run --coverage",
        "preview": "vite preview",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "lint:styles": "stylelint \"src/**/*.{css,scss,vue}\"",
        "lint:styles:fix": "stylelint \"src/**/*.{css,scss,vue}\" --fix",
        "format": "prettier --write \"src/**/*.{js,ts,vue,json,scss,css,md}\" \"src/__e2e__/features/**/*.feature\"",
        "format:check": "prettier --check \"src/**/*.{js,ts,vue,json,scss,css,md}\" \"src/__e2e__/features/**/*.feature\"",
        "prepare": "husky"
    },
    "devDependencies": {
        "@capacitor/android": "^7.0.0",
        "@capacitor/cli": "^7.0.0",
        "@capacitor/ios": "^7.0.0",
        "@eslint/js": "^9.0.0",
        "@playwright/test": "^1.58.2",
        "@testing-library/user-event": "^14.6.1",
        "@testing-library/vue": "^8.1.0",
        "@types/node": "^25.2.3",
        "@typescript-eslint/eslint-plugin": "^8.55.0",
        "@typescript-eslint/parser": "^8.55.0",
        "@vitejs/plugin-vue": "^6.0.1",
        "@vitest/coverage-v8": "^4.0.18",
        "@vue/tsconfig": "^0.8.1",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-alias": "^1.1.2",
        "eslint-plugin-import-x": "^4.16.1",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-vue": "^10.7.0",
        "globals": "^17.3.0",
        "happy-dom": "^20.5.0",
        "husky": "^9.1.7",
        "jsdom": "^27.4.0",
        "lint-staged": "^16.2.7",
        "pinia": "^3.0.4",
        "playwright-bdd": "^8.4.2",
        "postcss": "^8.5.6",
        "postcss-html": "^1.8.1",
        "postcss-scss": "^4.0.9",
        "prettier": "^3.8.1",
        "prettier-plugin-gherkin": "^3.1.3",
        "sass-embedded": "^1.97.3",
        "stylelint": "^17.2.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-scss": "^7.0.0",
        "typescript": "^5.9.3",
        "vite": "^7.2.4",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.0.18",
        "vue": "^3.5.24",
        "vue-eslint-parser": "^10.2.0",
        "vue-i18n": "^11.2.8",
        "vue-router": "^4.6.4",
        "vue-tsc": "^3.2.4"
    },
    "lint-staged": {
        "src/**/*.{js,ts,vue}": [
            "prettier --write",
            "eslint --fix"
        ],
        "src/**/*.{css,scss}": [
            "stylelint --fix",
            "prettier --write"
        ],
        "src/**/*.vue": [
            "stylelint --fix"
        ],
        "src/**/*.{json,md}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@capacitor/app": "^7.0.0",
        "@capacitor/core": "^7.0.0",
        "@capacitor/geolocation": "^7.0.0",
        "@capacitor/network": "^7.0.0",
        "@heroicons/vue": "^2.2.0",
        "@softour/global-front-components": "^1.9.0",
        "@softour/global-front-tokens-private": "^1.1.0",
        "@softour/maas-users-micro-front-private": "^1.2.1",
        "axios": "^1.16.0"
    }
}
